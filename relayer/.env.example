# Sepolia private key for the operator wallet that pays gas for every drip.
# Fund this address with some Sepolia ETH before deploying.
RELAYER_PRIVATE_KEY=0xYourSepoliaPrivateKey

# Address of the operator wallet — derived from RELAYER_PRIVATE_KEY.
# Optional: leave blank to let the relayer compute it from the key.
# Setting it explicitly is useful for ops visibility and lets /api/health
# return the address without loading the private key.
RELAYER_ADDRESS=

# Deployed TokenFaucet.sol contract address.
FAUCET_ADDRESS=0xYourFaucetContractAddress

# Optional — defaults to publicnode if unset.
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
